{
  "name": "3dog-node-backend",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-powered 3D object generation backend — craft3d + LangGraph agents",
  "scripts": {
    "build": "cd services/craft3d && npm run build",
    "test": "cd services/craft3d && npm test",
    "deps:dev": "cd services/craft3d && npm run deps:dev",
    "deps:prod": "cd services/craft3d && npm run deps:prod",
    "docker:build": "docker compose -f infra/docker-compose.yml build",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "docker:stop": "docker compose -f infra/docker-compose.yml stop",
    "docker:ps": "docker compose -f infra/docker-compose.yml ps",
    "docker:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "docker:ghcr:up": "docker compose -f infra/docker-compose.ghcr.yml up -d",
    "docker:ghcr:up:pull": "docker compose -f infra/docker-compose.ghcr.yml up -d --pull always",
    "docker:ghcr:pull": "docker compose -f infra/docker-compose.ghcr.yml pull",
    "docker:ghcr:down": "docker compose -f infra/docker-compose.ghcr.yml down",
    "docker:ghcr:ps": "docker compose -f infra/docker-compose.ghcr.yml ps",
    "docker:ghcr:logs": "docker compose -f infra/docker-compose.ghcr.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
